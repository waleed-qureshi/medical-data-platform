{
  "name": "medical-data-platform-backend",
  "version": "0.1.0",
  "description": "Backend REST API for medical data processing",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "knex migrate:latest --env development",
    "migrate:test": "knex migrate:latest --env test",
    "test": "cross-env NODE_ENV=test USE_MOCK_DB=true jest --runInBand",
    "test:integration": "cross-env NODE_ENV=test USE_MOCK_DB=false jest --runInBand",
    "test:watch": "cross-env NODE_ENV=test USE_MOCK_DB=true jest --watch"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^2.5.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.5.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.3"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "setupFilesAfterEnv": [
      "<rootDir>/__tests__/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "__tests__/jest.setup.js",
      "__tests__/setupDb.js"
    ]
  }
}
